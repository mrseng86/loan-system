DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/loan_management
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
TESTING=false
AUTO_CREATE_TABLES=true
SEED_DEFAULT_ADMIN=true
PERKESO_CHECK_URL=https://eis.perkeso.gov.my/eisportal/insured/appl/check
PERKESO_TIMEOUT_MS=30000
PERKESO_HEADLESS=true

# AI moderation. Set AI_PROVIDER to "ollama" (free, local), "gemini"
# (Google AI Studio free tier) or "disabled". Pull a model first with for
# example `ollama pull gemma2:2b`.
AI_PROVIDER=ollama
AI_MODEL=gemma2:2b
AI_TIMEOUT_SECONDS=60
OLLAMA_BASE_URL=http://localhost:11434
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
